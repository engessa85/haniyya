{
  "expo": {
    "name": "haniyya",
    "slug": "haniyya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fox.png",
    "scheme": "haniyya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/fox.png",
        "backgroundColor": "#F5EFE6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.engessa85.haniyya"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/fox.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/fox.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be6474e7-7413-4b16-ba97-9b9fe7d8ebd7"
      }
    }
  }
}